# ==========================================
# 模型配置
# ==========================================
MODEL_PROVIDER=tongyi
CHAT_MODEL_NAME=qwen-max
DASHSCOPE_API_KEY=your_api_key_here

# OpenAI配置（可选）
# OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# 服务配置
# ==========================================
HOST=0.0.0.0
PORT=8000

# ==========================================
# API安全配置
# ==========================================
API_KEY=your_secure_api_key_here
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# 数据库配置
# ==========================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=career_planning_db

# ==========================================
# 数据库代理/中继服务配置
# ==========================================
PROXY_API_URL=http://localhost:8001
PROXY_API_KEY=proxy_secret_key

RELAY_MODE=false
RELAY_API_URL=http://localhost:8002
RELAY_API_KEY=relay_secret_key_123
RELAY_CLIENT_ID=client_001
